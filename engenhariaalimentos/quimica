<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Semana Acadêmica - UFFS</title>

<style>
body {
  font-family: Arial, sans-serif;
  margin: 0;
  background: #f4f6f5;
}

header {
  background: linear-gradient(90deg, #1b5e20, #2e7d32);
  color: white;
  text-align: center;
  padding: 40px 20px;
}

.botao {
  display: inline-block;
  margin-top: 15px;
  background: #ffca28;
  padding: 12px 20px;
  border-radius: 8px;
  text-decoration: none;
  color: black;
  font-weight: bold;
}

section {
  padding: 40px 20px;
  max-width: 1100px;
  margin: auto;
}

h2 {
  text-align: center;
  color: #1b5e20;
}

.agenda {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
}

.dia {
  background: white;
  border-radius: 12px;
  padding: 20px;
  width: 280px;
}

.galeria {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 10px;
}

.galeria img {
  width: 100%;
  border-radius: 10px;
}

.organizadores {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
}

.membro {
  background: white;
  padding: 15px;
  border-radius: 12px;
  width: 250px;
  text-align: center;
}

.logos {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 20px;
}

.logos img {
  width: 120px;
  background: white;
  padding: 10px;
  border-radius: 10px;
}

footer {
  background: #1b5e20;
  color: white;
  text-align: center;
  padding: 20px;
}
</style>
</head>

<body>

<header>
  <h1>Semana Acadêmica</h1>
  <p>Engenharia de Alimentos e Engenharia Química - UFFS</p>

  <a href="https://forms.gle/SEU-LINK-AQUI" class="botao" target="_blank">
    Fazer Inscrição
  </a>
</header>

<section>
  <h2>📅 Programação</h2>

  <div class="agenda">
    <div class="dia">
      <h3>Segunda-feira</h3>
      <p>19h00 - Abertura</p>
      <p>20h00 - Palestra</p>
    </div>

    <div class="dia">
      <h3>Terça-feira</h3>
      <p>19h00 - Minicursos</p>
      <p>21h00 - Coffee Break</p>
    </div>

    <div class="dia">
      <h3>Quarta-feira</h3>
      <p>19h00 - Workshop</p>
      <p>21h30 - Encerramento</p>
    </div>
  </div>
</section>

<section>
  <h2>📍 Local</h2>
  <iframe src="https://www.google.com/maps?q=UFFS+Laranjeiras+do+Sul&output=embed"
  width="100%" height="300" style="border-radius:10px;"></iframe>
</section>

<section>
  <h2>🖼️ Galeria</h2>
  <div class="galeria">
    <img src="https://via.placeholder.com/300">
    <img src="https://via.placeholder.com/300">
  </div>
</section>

<section>
  <h2>👥 Organizadores</h2>
  <div class="organizadores">
    <div class="membro">
      <h3>Coordenação</h3>
      <p>Rebeca Duarte de Souza</p>
    </div>
  </div>
</section>

<section>
  <h2>🤝 Apoio</h2>
  <div class="logos">
    <img src="https://via.placeholder.com/150">
    <img src="https://via.placeholder.com/150">
  </div>
</section>

<footer>
  <p>© 2026 - UFFS</p>
</footer>

</body>
</html>
